{
  "name": "living-governance",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0 <23"
  },
  "scripts": {
    "check:node": "node scripts/check-node-version.mjs",
    "predev": "npm run check:node",
    "dev": "next dev",
    "prebuild": "npm run check:node",
    "build": "next build",
    "prestart": "npm run check:node",
    "start": "next start",
    "lint": "next lint",
    "precheck:ontology": "npm run check:node",
    "check:ontology": "node scripts/check-ontology.mjs",
    "precheck:knowledge": "npm run check:node",
    "check:knowledge": "npx tsc --noEmit -p tsconfig.knowledge.json",
    "precheck:app": "npm run check:node",
    "check:app": "npm run build",
    "check:package:frameworks": "(cd packages/frameworks && npx tsc --noEmit)",
    "check:package:threats": "(cd packages/threats && npx tsc --noEmit)",
    "check:ci": "npm run check:ontology && npm run check:knowledge && npm run check:app && npm run check:package:frameworks && npm run check:package:threats"
  },
  "dependencies": {
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.7",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "mcp-handler": "^1.1.0",
    "next": "^15.5.12",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  }
}
